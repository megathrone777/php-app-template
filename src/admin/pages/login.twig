{% extends "admin/blocks/layout/auth.twig" %}

{% block content %}
	<div class="container">
		<div class="flex">
			<div class="pt-5 text-center">
				<h1 class="mb-3">{{ title }}</h1>

				<form
					action="/src/admin/helpers/authenticate.php"
					class="
						flex flex-col
						gap-y-3
					"
					method="POST"
				>
					<div>
						<input
							name="login"
							placeholder="Login"
							required
							type="text"
						>
					</div>

					<div>
						<input
							name="password"
							placeholder="Password"
							required
							type="password"
						>
					</div>

					<button type="submit">Login</button>
				</form>

				{% if error %}
					<div>
						<p>{{ error }}</p>
						<button type="button">X</button>
					</div>
				{% endif %}
			</div>
		</div>
	</div>
{% endblock %}
